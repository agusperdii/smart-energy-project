# Energizer Frontend Environment Variables

# The target API endpoint where telemetry simulation payloads will be POSTed.
# If this is left blank, commented, or is offline, the frontend will automatically
# fall back to localized mock simulation intelligence for easier testing.
VITE_API_SIMULATION_URL=http://localhost:5000/simulate

# Supabase Realtime Configuration
# Replace these with your actual Supabase project credentials.
# If these are left blank or incorrect, the dashboard will fall back to local sensor simulation.
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
